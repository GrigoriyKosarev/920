<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Extend MPS Control Panel to add Import from Excel button and Time Range selector -->
    <t t-name="bio_mrp_mps.MrpMpsControlPanel.Regular"
       t-inherit="mrp_mps.MrpMpsControlPanel.Regular"
       t-inherit-mode="extension"
       owl="1">

        <!-- Add Import button after "Add a Product" button -->
        <xpath expr="//button[@t-on-click.stop='_onClickCreate']" position="after">
            <Dropdown togglerClass="'btn btn-light d-inline-block'">
                <t t-set-slot="toggler">
                    <i class="fa fa-calendar me-1"/>
                    <span class="dropdown-toggle o_dropdown_title">Time Range</span>
                </t>
                <DropdownItem
                    class="{ o_menu_item: true, selected: getManufacturingPeriod() === 'month' }"
                    parentClosingMode="'none'"
                    onSelected="() => this._onSetManufacturingPeriod('month')">
                        Monthly
                </DropdownItem>
                <DropdownItem
                    class="{ o_menu_item: true, selected: getManufacturingPeriod() === 'week' }"
                    parentClosingMode="'none'"
                    onSelected="() => this._onSetManufacturingPeriod('week')">
                        Weekly
                </DropdownItem>
                <DropdownItem
                    class="{ o_menu_item: true, selected: getManufacturingPeriod() === 'day' }"
                    parentClosingMode="'none'"
                    onSelected="() => this._onSetManufacturingPeriod('day')">
                        Daily
                </DropdownItem>
            </Dropdown>

            <button type="button"
                    class="btn btn-secondary o_mps_import_excel"
                    t-on-click.stop="_onClickImportExcel">
                <i class="fa fa-upload"/> Import from Excel
            </button>
        </xpath>
    </t>

</templates>
